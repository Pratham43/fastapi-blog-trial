# Database Settings
POSTGRES_USER=bloguser
POSTGRES_PASSWORD=blogpassword
POSTGRES_DB=blogdb
# For Docker Compose: postgresql+psycopg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}
# For local run: postgresql+psycopg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB}
DATABASE_URL=postgresql+psycopg://bloguser:blogpassword@db:5432/blogdb

# JWT Authentication
SECRET_KEY=b5750c2a6f772a57eff58e901f1f50e1dcbde8b42a2b54d188e568123193808c
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# AWS S3 Settings (Optional)
S3_BUCKET_NAME=my-blog-bucket
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT_URL=

# Upload limits
MAX_UPLOAD_SIZE_BYTES=5242880

# Pagination
POSTS_PER_PAGE=10

# Password Reset
RESET_TOKEN_EXPIRE_MINUTES=60

# SMTP / Email Settings (Optional)
MAIL_SERVER=localhost
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@example.com
MAIL_USE_TLS=true

# Frontend URL
FRONTEND_URL=http://localhost:5173

# Redis / Valkey Caching Settings
# For Docker Compose: redis://cache:6379/0
# For local run: redis://localhost:6379/0
REDIS_URL=redis://cache:6379/0
REDIS_CACHE_EXPIRE_SECONDS=300

# Google OAuth2 Credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8060/api/v1/users/auth/google/callback

# Production Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=console
