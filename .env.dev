# ============================================================
# DEV ENVIRONMENT (.env.dev)
# For use with: docker compose -f docker-compose.dev.yml up
# ============================================================

# --- PostgreSQL ---
POSTGRES_USER=blogdev
POSTGRES_PASSWORD=blogdev
POSTGRES_DB=blogdev_db
DATABASE_URL=postgresql+psycopg://blogdev:blogdev@db:5432/blogdev_db

# --- JWT Auth ---
SECRET_KEY=dev-insecure-secret-key-do-not-use-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- MinIO (Local S3) ---
# backend points to minio service name inside docker network
S3_ENDPOINT_URL=http://minio:9000
S3_BUCKET_NAME=blog-uploads
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin

# --- Pagination ---
POSTS_PER_PAGE=10

# --- Password Reset ---
RESET_TOKEN_EXPIRE_MINUTES=60

# --- Upload Limits ---
MAX_UPLOAD_SIZE_BYTES=5242880

# --- Email (disabled for dev — console output only) ---
MAIL_SERVER=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=dev@localhost
MAIL_USE_TLS=false

# --- Frontend (Vite dev server) ---
FRONTEND_URL=http://localhost:5173

# --- Valkey/Redis Cache ---
REDIS_URL=redis://cache:6379/0
REDIS_CACHE_EXPIRE_SECONDS=60

# --- Google OAuth (optional for dev — leave as placeholders) ---
GOOGLE_CLIENT_ID=placeholder-client-id
GOOGLE_CLIENT_SECRET=placeholder-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8060/api/v1/users/auth/google/callback

# --- Logging (human-readable console output for dev) ---
LOG_LEVEL=DEBUG
LOG_FORMAT=console
